#!/bin/bash
# Pre-commit hook for git (multi-scope)
# Blocks commits if any scope's pipeline is still in progress.
# Also validates agent divergence, hardcodes, and affected-package tests.
# Activated via: git config core.hooksPath .opencode/pipeline
# (git requires the exact filename 'pre-commit', no extension)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
STATE_FILE="$SCRIPT_DIR/state.json"

# No state file = no pipeline has ever run = nothing in progress.
# (Blocking here would prevent the very first commit after install.)
if [ ! -f "$STATE_FILE" ]; then
  PIPELINE_STATUS="inactive"
elif command -v python3 >/dev/null 2>&1; then
  PIPELINE_STATUS=$(python3 -c "
import json
state = json.load(open('$STATE_FILE'))
scopes = state.get('scopes', {})
# Block commit if any scope is still active (not completed)
active_scopes = [name for name, s in scopes.items() if s.get('active', False)]
if active_scopes:
    print('active:' + ','.join(active_scopes))
else:
    print('inactive')
" 2>/dev/null)
elif command -v node >/dev/null 2>&1; then
  PIPELINE_STATUS=$(node -e "
const s = require(process.argv[1]);
const a = Object.entries(s.scopes || {}).filter(([, v]) => v && v.active).map(([k]) => k);
console.log(a.length ? 'active:' + a.join(',') : 'inactive');
" "$STATE_FILE" 2>/dev/null)
else
  echo "⚠ pre-commit: neither python3 nor node available — pipeline check skipped"
  PIPELINE_STATUS="inactive"
fi

if [[ "$PIPELINE_STATUS" == active:* ]]; then
  ACTIVE_SCOPES="${PIPELINE_STATUS#active:}"
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  COMMIT BLOCKED: Pipeline(s) in progress                     ║"
  echo "║  Active scopes: $ACTIVE_SCOPES"
  echo "║                                                              ║"
  echo "║  Complete ALL pipelines before committing.                   ║"
  echo "║  If you are done, mark the todos as 'completed'              ║"
  echo "║  in todowrite to close each scope.                           ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

echo "✓ Pipeline check: OK"

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# ── Agent divergence check (.claude/agents ↔ .opencode/agents) ────────────────
# .opencode agent bodies must be identical to the canonical .claude versions
# (only the frontmatter differs per runtime). Blocks if any agent has diverged.
# Only runs when agent files are staged.
AGENTS_STAGED=$(git diff --cached --name-only | grep -E '^\.(claude|opencode)/agents/' || true)
if [ -n "$AGENTS_STAGED" ]; then
  SYNC_SCRIPT="$ROOT/scripts/sync-agents.ts"
  if [ -f "$SYNC_SCRIPT" ] && command -v npx >/dev/null 2>&1; then
    echo ""
    echo "--- Agent divergence check ---"
    AGENT_CHECK_OUT=$(cd "$ROOT" && npx -y tsx "$SYNC_SCRIPT" --check 2>&1)
    AGENT_CHECK_RC=$?
    echo "$AGENT_CHECK_OUT" | grep -v "npm warn" || true
    if [ "$AGENT_CHECK_RC" -ne 0 ]; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  COMMIT BLOCKED: Agent divergence detected                  ║"
      echo "║  (.claude/agents ↔ .opencode/agents)                        ║"
      echo "║                                                              ║"
      echo "║  Regenerate .opencode agents from canonical .claude:        ║"
      echo "║    npx tsx scripts/sync-agents.ts                            ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      exit 1
    fi
  fi
fi

# ── Hardcode validation ──────────────────────────────────────────────────────
# Scans staged files for absolute paths, hardcoded sockets,
# and container names with a project prefix.
HARDCODE_SCRIPT="$ROOT/scripts/validate-hardcodes.sh"

if [ -x "$HARDCODE_SCRIPT" ]; then
  STAGED_FILES=$(git diff --cached --name-only)
  if [ -n "$STAGED_FILES" ]; then
    echo ""
    echo "--- Hardcode validation ---"
    # Pass staged files to the validation script
    HARDCODE_OUTPUT=$(echo "$STAGED_FILES" | xargs "$HARDCODE_SCRIPT" 2>&1) || {
      echo "$HARDCODE_OUTPUT"
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  COMMIT BLOCKED: Hardcoded values detected                   ║"
      echo "║                                                              ║"
      echo "║  Fix the hardcoded values before committing.                 ║"
      echo "║  If a hardcoded value is legitimate, add:                    ║"
      echo "║    # hardcode-ok: <reason>                                   ║"
      echo "║  to the affected file.                                       ║"
      echo "║  Allowlisted files: .claude/settings.local.json              ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      exit 1
    }
    echo "$HARDCODE_OUTPUT"
  fi
fi

# ── Affected-package test runner ──────────────────────────────────────────────
# Detects which monorepo packages are affected by staged changes and runs their
# tests. Blocks commit if any test fails. Supports pnpm workspaces.
#
# Mapping: apps/<dir>/** → filter by dir, packages/<shared>/** → all apps.
# Bypass: SKIP_TESTS=1 git commit ...

if [ "${SKIP_TESTS:-}" = "1" ]; then
  echo ""
  echo "--- Test validation: SKIPPED (SKIP_TESTS=1) ---"
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Only run tests in monorepo projects (pnpm workspaces detected)
WORKSPACE_FILE=""
for f in pnpm-workspace.yaml pnpm-workspace.yml; do
  if [ -f "$ROOT/$f" ]; then
    WORKSPACE_FILE="$ROOT/$f"
    break
  fi
done

if [ -z "$WORKSPACE_FILE" ] && command -v pnpm >/dev/null 2>&1; then
  # Check package.json for workspaces field
  if [ -f "$ROOT/package.json" ] && grep -q '"workspaces"' "$ROOT/package.json" 2>/dev/null; then
    WORKSPACE_FILE="$ROOT/package.json"
  fi
fi

if [ -z "$WORKSPACE_FILE" ]; then
  exit 0  # Not a monorepo — skip test validation
fi

# Collect affected app dirs as a newline-delimited list. No associative arrays:
# macOS ships bash 3.2, which lacks `declare -A`.
AFFECTED=""
HAS_SHARED=false

while IFS= read -r file; do
  case "$file" in
    apps/*/*)
      AFFECTED+="$(printf '%s' "$file" | cut -d'/' -f1-2)"$'\n'
      ;;
    packages/*/*)
      HAS_SHARED=true
      ;;
    *) ;; # scripts, config, .opencode, .claude — no app tests needed
  esac
done <<< "$STAGED_FILES"

# Shared package change → all apps need testing
if $HAS_SHARED; then
  for app_dir in "$ROOT"/apps/*/; do
    [ -d "$app_dir" ] && AFFECTED+="apps/$(basename "$app_dir")"$'\n'
  done
fi

AFFECTED_LIST=$(printf '%s' "$AFFECTED" | grep -v '^$' | sort -u | xargs)

if [ -n "$AFFECTED_LIST" ]; then
  echo ""
  echo "--- Test validation ---"
  echo "Packages affected by staged changes: $AFFECTED_LIST"

  FAILED_PKGS=""
  for pkg_dir in $AFFECTED_LIST; do
    echo "  → Running tests: $pkg_dir"
    if ! (cd "$ROOT" && pnpm --filter "./$pkg_dir" test --passWithNoTests 2>&1); then
      FAILED_PKGS="$FAILED_PKGS $pkg_dir"
    fi
  done

  if [ -n "$FAILED_PKGS" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  COMMIT BLOCKED: Tests failed                               ║"
    echo "║  Packages with failures: $FAILED_PKGS"
    echo "║                                                              ║"
    echo "║  Fix the tests before committing.                            ║"
    echo "║  Temporary bypass (not recommended):                         ║"
    echo "║    SKIP_TESTS=1 git commit ...                               ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    exit 1
  fi
  echo "✓ All tests passed"
fi

exit 0
