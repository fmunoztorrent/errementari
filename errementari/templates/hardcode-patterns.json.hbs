{
  "$description": "Hardcoded-value patterns forbidden in the repository. Used by validate-hardcodes.sh and pipeline-enforcer.js. Keep in sync with CLAUDE.md §Automatic validations.",
  "patterns": [
    {
      "id": "absolute-user-path",
      "description": "Absolute user path (not portable across machines)",
      "regex": "/Users/[A-Za-z0-9_]+|/home/[A-Za-z0-9_]+|C:\\\\Users\\\\[A-Za-z0-9_]+",
      "suggestion": "Use relative paths, $HOME, or $(git rev-parse --show-toplevel)"
    },
    {
      "id": "hardcoded-socket",
      "description": "Docker/Podman socket hardcoded without a variable",
      "regex": "DOCKER_HOST=unix://",
      "suggestion": "Use the Makefile (make infra) or dynamic detection with $COMPOSE"
    },
    {
      "id": "container-name-prefix",
      "description": "Container name with project prefix (fragile if the dir changes)",
      "regex": "{{slug}}-[a-z]+-[0-9]+",
      "suggestion": "Use $COMPOSE exec <service> instead of the container name"
    }
  ],
  "allowlist": {
    "files": [
      ".claude/settings.local.json",
      ".opencode/pipeline/hardcode-patterns.json"
    ],
    "comments": [
      "# hardcode-ok:"
    ]
  }
}
