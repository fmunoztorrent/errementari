{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": ["CLAUDE.md"],
  "watcher": {
    "ignore": ["spec/archived/**", "spdd/analysis/**", "spdd/prompt/**"]
  },
  "default_agent": "pipeline",
  "plugin": ["errementari"],
  "skills": {
    "paths": [
      ".claude/skills",
      "node_modules/errementari/skills"
    ]
  },
  "agent": {
    "pipeline": {
      "permission": {
        "task": {
          "*": "deny",
          "spec": "allow",
          "architect": "allow",
          "qa": "allow",
          "backend": "allow"{{#if hasFrontend}},
          "frontend": "allow"{{/if}}
        }
      }
    }
  },
  "command": {
    "task": {
      "template": "Classify and run the corresponding pipeline (SPDD + SDD + BDD + TDD) following the instructions in CLAUDE.md:\n\n\{{input}}",
      "description": "Invokes the automatic pipeline (feature/bugfix/debug/chore) with SPDD Canvas + todowrite + transition announcements",
      "subtask": false
    }
  }
}
