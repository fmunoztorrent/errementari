{
  "permissions": {
    "allow": [
      "Read(.claude/**)",
      "mcp__context7__*",
      "Skill(ponytail)",
      "Skill(caveman)",
      "Skill(find-skills)"{{#each permCommands}},
      "Bash({{this}}:*)"{{/each}}
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination.sh register claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination.sh release claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination-claude-hook.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .opencode/pipeline/pipeline-cli.mjs guard-edit"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node .opencode/pipeline/pipeline-cli.mjs check-activation"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node .opencode/pipeline/pipeline-cli.mjs sync-todos"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'HOOK: Task completed. Before closing: (1) update the spec in spec/ marking completed tasks; (2) add an entry to .claude/LEARNINGS.md if you learned something non-obvious; (3) update CLAUDE.md if there are architectural changes, new conventions or decisions that must persist.'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .opencode/pipeline/close-pending.json ] && command -v npx >/dev/null 2>&1 && npx -y tsx scripts/extract-learnings.ts 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
