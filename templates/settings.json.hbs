{
  "permissions": {
    "allow": [
      "Read(.claude/**)",
      "mcp__context7__*"{{#each permCommands}},
      "Bash({{this}})"{{/each}}
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination.sh register claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination.sh release claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination-claude-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'HOOK: Tarea completada. Antes de cerrar: (1) actualiza el spec en spec/ marcando tareas completadas; (2) agrega una entrada en .claude/LEARNINGS.md si aprendiste algo no obvio; (3) actualiza CLAUDE.md si hay cambios arquitecturales, nuevas convenciones o decisiones que deben persistir.'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .opencode/pipeline/close-pending.json ] && npx tsx scripts/extract-learnings.ts 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
