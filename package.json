{
  "name": "errementari",
  "version": "1.1.0",
  "description": "Dual-tool (Claude Code + opencode) development pipeline harness",
  "bin": {
    "errementari": "bin/cli.js"
  },
  "files": [
    "dist/",
    "harness/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "lint": "biome check src",
    "format": "biome format --write src",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pipeline",
    "harness",
    "claude-code",
    "opencode",
    "tdd"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "just-diff": "^6.0.2",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
